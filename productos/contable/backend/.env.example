# ============================================================================
# Flask
# ============================================================================
FLASK_ENV=development
FLASK_APP=app
FLASK_RUN_PORT=5001
SECRET_KEY=change-me-in-production

# ============================================================================
# Supabase
# ============================================================================
# Cuando se cree el proyecto Supabase, completar estos valores.
# En arranque local sin Supabase, dejarlos vacíos: el backend levantará pero
# los endpoints que lo usen devolverán 503.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Bucket privado donde se guardan las imágenes de facturas
SUPABASE_BUCKET_FACTURAS=facturas-imagenes

# ============================================================================
# Encriptación
# ============================================================================
# Llave maestra Fernet para encriptar las api_keys de los clientes.
# Generar con:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=

# ============================================================================
# Baileys (bot WhatsApp)
# ============================================================================
# Shared secret entre Flask y Baileys (header X-Baileys-Token).
# Generar con:  openssl rand -hex 32
BAILEYS_SHARED_SECRET=
BAILEYS_INTERNAL_URL=http://localhost:3001

# ============================================================================
# AFIP
# ============================================================================
# En MVP local no se usa: si AFIP_CERT_PATH está vacío, services/afip.py
# corre en modo stub y devuelve datos mock.
AFIP_CERT_PATH=
AFIP_KEY_PATH=
AFIP_CUIT=
AFIP_PRODUCTION=false

# ============================================================================
# Observabilidad (opcional)
# ============================================================================
SENTRY_DSN=
LOG_LEVEL=INFO
