# ============================================================
# SERVIDOR
# ============================================================
PORT=3000

# ============================================================
# CLIENTE ACTIVO
# ============================================================
# Nombre de la carpeta dentro de src/clients/ que se va a cargar.
# Para cambiar de cliente (ej: taller mecanico):
#   1. Copiar src/clients/sofia/ a src/clients/taller/
#   2. Editar prompt.md y config.ts del nuevo cliente
#   3. Cambiar esta variable a CLIENT_NAME=taller
CLIENT_NAME=sofia

# ============================================================
# EVOLUTION API (WhatsApp)
# ============================================================
EVOLUTION_API_URL=http://tu-evolution-host:8080
EVOLUTION_API_KEY=tu_evolution_api_key

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# GOOGLE SERVICE ACCOUNT
# ============================================================
# Ruta al archivo JSON del Service Account.
# Pasos:
#   1. Crear Service Account en Google Cloud Console
#   2. Habilitar Google Sheets API y Google Docs API
#   3. Descargar el JSON de credenciales y guardarlo (ej: ./credentials/service-account.json)
#   4. Compartir el Google Doc y el Google Sheet con el email del Service Account
#      (ej: my-bot@my-project.iam.gserviceaccount.com) con permisos de Editor (Sheet) y Viewer (Doc)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# ============================================================
# GUARDRAILS
# ============================================================
NSFW_THRESHOLD=0.7
