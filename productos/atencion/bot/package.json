{
  "name": "whatsapp-ai-agent",
  "version": "1.0.0",
  "description": "Servidor de WhatsApp con agente de IA. Evolution API + OpenAI + Google Sheets/Docs.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "node -e \"require('fs').cpSync('src/clients','dist/clients',{recursive:true,filter:(s)=>{try{return require('fs').statSync(s).isDirectory()||s.endsWith('.md')}catch{return false}}})\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "openai": "^4.65.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
